<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(GameLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="@typeof(GameLayout)">
            <div class="menu-page">
                <h1 class="menu-title">404</h1>
                <p class="menu-subtitle">No se encontró la página</p>
                <a href="/" class="btn-play primary" style="text-decoration:none;">Volver al menú</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>
