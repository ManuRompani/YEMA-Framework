@page "/admin"
@layout GameLayout
@inject NavigationManager Navigation

<div class="admin-layout">
    <div class="admin-topbar">
        <div class="admin-topbar-left">
            <a class="admin-back-link" href="/">&#x2190; Menú</a>
            <span class="admin-divider">|</span>
            <span class="admin-title">Panel Admin</span>
        </div>
        <div class="admin-session">Sesión: <span>admin</span></div>
    </div>

    <div class="admin-tabs">
        <button class="admin-tab @(activeTab == "words" ? "active" : "")" @onclick='() => activeTab = "words"'>
            &#x1F4C4; Palabras
        </button>
        <button class="admin-tab @(activeTab == "rules" ? "active" : "")" @onclick='() => activeTab = "rules"'>
            &#x2699;&#xFE0F; Reglas de Puntos
        </button>
    </div>

    <div class="admin-content">
        @if (activeTab == "words")
        {
            <WordsTab />
        }
        else
        {
            <RulesTab />
        }
    </div>
</div>

@code {
    private string activeTab = "words";
}
