@page "/login"

@using Cliente.JuegoAhorcado.Modelo
@using Cliente.JuegoAhorcado.Negocio

@layout GameLayout

@inject NavigationManager Navigation
@inject PlayerNegocio PlayerNegocio

<div class="login-page">
    <a class="back-link" href="/">&#x2190; Volver al menú</a>

    <div class="login-card">
        <div class="login-icon">&#x1F3AE;</div>
        <h1 class="login-title">@(isLogin ? "Iniciá sesión" : "Registrate")</h1>
        <p class="login-subtitle">Para jugar tenés que estar identificado</p>

        <div class="auth-tabs">
            <button class="auth-tab @(isLogin ? "active" : "")" @onclick="() => isLogin = true">Iniciar sesión</button>
            <button class="auth-tab @(!isLogin ? "active" : "")" @onclick="() => isLogin = false">Registrarse</button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <p style="color: var(--accent-red); font-size: 0.8rem; margin-bottom: 1rem;">@errorMessage</p>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <p style="color: var(--accent-green); font-size: 0.8rem; margin-bottom: 1rem;">@successMessage</p>
        }

        <EditForm Model="model" OnValidSubmit="HandleSubmit">
            <div class="form-group">
                <label class="form-label">USUARIO</label>
                <input class="form-input" type="text" placeholder="Tu nombre de usuario" @bind="model.Username" disabled="@isLoading" />
            </div>

            <div class="form-group">
                <label class="form-label">CONTRASEÑA</label>
                <input class="form-input" type="password" placeholder="Tu contraseña" @bind="model.Password" disabled="@isLoading" />
            </div>

            <button type="submit" class="btn-submit" disabled="@isLoading">
                @(isLoading ? "Procesando..." : (isLogin ? "¡A jugar!" : "Crear cuenta"))
            </button>
        </EditForm>

        <p class="login-demo">Demo admin: <span>admin / admin123</span></p>
    </div>
</div>

@code {
    private bool isLogin = true;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";
    private LoginModel model = new();

    private async Task HandleSubmit()
    {
        errorMessage = "";
        successMessage = "";
        isLoading = true;

        try
        {
            if (isLogin)
            {
                Navigation.NavigateTo("/jugar");
            }
            else
            {
                Player newPlayer = new Player
                {
                    Id = 0,
                    Name = model.Username,
                    Password = model.Password,
                    Rounds = 0,
                    Points = 0,
                    Role = new Role
                    {
                        Id = 2,
                        Name = "player"
                    }
                };

                var registered = await PlayerNegocio.Register(newPlayer);

                successMessage = $"¡Cuenta creada! Bienvenido {registered.Name}";

                await Task.Delay(1000);

                Navigation.NavigateTo("/jugar");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
