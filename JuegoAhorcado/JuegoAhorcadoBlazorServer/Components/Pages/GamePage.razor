@page "/jugar"
@rendermode InteractiveServer
@using JuegoAhorcadoBlazorServer.Services
@using JuegoAhorcadoBlazorServer.Negocio
@inject NavigationManager Navigation
@inject ScoreNegocio ScoreNegocio
@inject GameNegocio GameNegocio
@inject SessionState Session

@if (NoWordsAvailable)
{
    <div class="game-layout">
        <div class="game-content" style="justify-content: center; align-items: center; min-height: 60vh;">
            <div style="text-align: center;">
                <div style="font-size: 3rem; margin-bottom: 1rem;">&#x1F4AD;</div>
                <h2 style="margin-bottom: 0.5rem;">En este momento no hay palabras para jugar</h2>
                <p style="color: #999; margin-bottom: 2rem;">Esperá a que el admin agregue palabras nuevas</p>
                <button class="btn-modal primary" @onclick="GoToMenu">Volver al menú</button>
            </div>
        </div>
    </div>
}
else
{
<div class="game-layout">
    <div class="game-top-bar">
        <button class="exit-btn" @onclick="ShowExitModal">&#x2715; Salir</button>

        <div class="game-stats">
            <div class="game-stat">
                <div class="game-stat-label">RONDA</div>
                <div class="game-stat-value round">@Round</div>
            </div>
            <div class="game-stat">
                <div class="game-stat-label">PUNTOS</div>
                <div class="game-stat-value points">@Points</div>
            </div>
            <div class="game-stat">
                <div class="game-stat-label">VIDAS</div>
                <div class="game-stat-value lives">@GetHearts()</div>
            </div>
        </div>

        <div class="game-user">@Username</div>
    </div>

    <div class="game-content">
        <div class="game-sidebar">
            <div class="hangman-card">
                <HangmanDrawing Errors="Errors" />
                <p class="error-count">@Errors / 6 errores</p>
            </div>

            <div class="info-card">
                <div class="info-label">CATEGORÍA</div>
                <div class="category-badge">@Category</div>

                <div class="info-label">PISTA</div>
                <p class="hint-text">"@Hint"</p>
            </div>
        </div>

        <div class="game-main">
            <div class="word-display">
                @foreach (var row in WordRows)
                {
                    <div class="word-row">
                        @foreach (var cell in row)
                        {
                            @if (cell == " ")
                            {
                                <div class="letter-slot space"></div>
                            }
                            else if (cell == "_")
                            {
                                <div class="letter-slot">&nbsp;</div>
                            }
                            else
                            {
                                <div class="letter-slot revealed">@cell</div>
                            }
                        }
                    </div>
                }
            </div>

            <div class="keyboard">
                @foreach (var row in KeyboardRows)
                {
                    <div class="keyboard-row">
                        @foreach (var letter in row)
                        {
                            <button class="key-btn @GetKeyClass(letter)"
                                    @onclick="() => GuessLetter(letter)"
                                    disabled="@(UsedLetters.Contains(letter) || GameOver)">
                                @letter
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
}

@if (ShowWinModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">&#x1F389;</div>
            <h2 class="modal-title" style="color: #22c55e;">¡Ganaste!</h2>
            <p class="modal-message">La palabra era <span class="modal-word">@RevealedWord.ToUpper()</span></p>
            <p class="modal-message">Ganaste <span class="highlight">@RoundPoints puntos</span> en esta ronda</p>
            <div class="modal-buttons">
                <button class="btn-modal primary" @onclick="NextRound">Siguiente palabra</button>
                <button class="btn-modal accent" @onclick="GoToPositions">Ver posiciones</button>
            </div>
        </div>
    </div>
}

@if (ShowDefeatModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">&#x1F480;</div>
            <h2 class="modal-title defeat">¡Perdiste!</h2>
            <p class="modal-message">La palabra era <span class="modal-word">@RevealedWord.ToUpper()</span></p>
            <p class="modal-message">No llegaste a acumular puntos esta vez</p>
            <div class="modal-buttons">
                <button class="btn-modal accent" @onclick="GoToPositions">Ver tabla de posiciones</button>
                <button class="btn-modal primary" @onclick="GoToMenu">Volver al menú</button>
            </div>
        </div>
    </div>
}

@if (ShowExitModalFlag)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-icon">&#x26A0;&#xFE0F;</div>
            <h2 class="modal-title warning">¿Seguro que te vas?</h2>
            <p class="modal-message">Si salís ahora perdés los <span class="highlight">@Points puntos</span> acumulados. ¡No quedan guardados!</p>
            <div class="modal-buttons" style="flex-direction: row;">
                <button class="btn-modal primary" style="flex:1;" @onclick="() => ShowExitModalFlag = false">Seguir jugando</button>
                <button class="btn-modal danger" style="flex:1;" @onclick="GoToMenu">Salir igual</button>
            </div>
        </div>
    </div>
}

@code {
    private string Username = "";
    private int Round = 1;
    private int Points = 0;
    private int Lives = 6;
    private int Errors = 0;
    private string Hint = "";
    private string Category = "";
    private int RoundPoints = 0;
    private string MaskedWord = "";
    private string RevealedWord = "";
    private HashSet<char> UsedLetters = new();
    private bool NoWordsAvailable = false;
    private bool ShowDefeatModal = false;
    private bool ShowWinModal = false;
    private bool ShowExitModalFlag = false;
    private bool GameOver = false;

    private List<string> KeyboardRows = new()
    {
        "ABCDEFGHIJ",
        "KLMNÑOPQRS",
        "TUVWXYZ"
    };

    private List<List<string>> WordRows => ParseMaskedWord(MaskedWord);

    protected override async Task OnInitializedAsync()
    {
        Username = Session.CurrentUser?.Name ?? "Jugador";
        await StartNewGame();
    }

    private async Task StartNewGame()
    {
        GameState state = await GameNegocio.StartGameAsync();

        if (!string.IsNullOrEmpty(state.ErrorMessage))
        {
            NoWordsAvailable = true;
            return;
        }

        MaskedWord = state.MaskedWord;
        Lives = state.Lives;
        Hint = state.Hint;
        Category = state.Category;
        Errors = 0;
        GameOver = false;
        ShowDefeatModal = false;
        ShowWinModal = false;
        UsedLetters.Clear();
    }

    private string GetHearts()
    {
        return string.Concat(Enumerable.Repeat("\u2764\uFE0F ", Lives)).Trim();
    }

    private string GetKeyClass(char letter)
    {
        if (!UsedLetters.Contains(letter)) return "";
        return MaskedWord.ToUpper().Contains(letter) ? "correct" : "wrong";
    }

    private async Task GuessLetter(char letter)
    {
        if (UsedLetters.Contains(letter) || GameOver) return;

        UsedLetters.Add(letter);

        GameState state = await GameNegocio.GuessLetterAsync(letter);

        if (!string.IsNullOrEmpty(state.ErrorMessage))
            return;

        Lives = state.Lives;

        if (state.Status == "won")
        {
            GameOver = true;
            RevealedWord = state.RevealedWord;
            RoundPoints = 30;
            Points += RoundPoints;
            ShowWinModal = true;
        }
        else if (state.Status == "lost")
        {
            GameOver = true;
            RevealedWord = state.RevealedWord;
            ShowDefeatModal = true;
            await SendScore();
        }
        else
        {
            MaskedWord = state.MaskedWord;
            Errors = 6 - Lives;
        }
    }

    private async Task NextRound()
    {
        ShowWinModal = false;
        Round++;
        await StartNewGame();
    }

    private void ShowExitModal()
    {
        ShowExitModalFlag = true;
    }

    private async Task GoToMenu()
    {
        await SendScore();
        Navigation.NavigateTo("/");
    }

    private async Task SendScore()
    {
        if (Points > 0)
        {
            await ScoreNegocio.UpdateScore(Points, Round);
        }
    }

    private void GoToPositions()
    {
        Navigation.NavigateTo("/posiciones");
    }

    private List<List<string>> ParseMaskedWord(string maskedWord)
    {
        var words = new List<List<string>>();

        if (string.IsNullOrWhiteSpace(maskedWord))
            return words;

        string[] wordGroups = maskedWord.Split(new[] { "  " }, StringSplitOptions.RemoveEmptyEntries);

        foreach (string group in wordGroups)
        {
            var letters = group.Split(' ', StringSplitOptions.RemoveEmptyEntries).ToList();
            if (letters.Any())
                words.Add(letters);
        }

        return words;
    }
}
